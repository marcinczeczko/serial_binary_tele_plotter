{
    "streams": {
        "pid": {
            "name": "PID Telemetry",
            "panel_type": "pid",
            "frame": {
                "stream_id": 1,
                "endianness": "little",
                "packed": true,
                "fields": [
                    { "name": "loopCntr", "type": "u32" },
                    { "name": "motor", "type": "u8" },
                    { "name": "setpoint", "type": "f32" },
                    { "name": "measurement", "type": "f32" },
                    { "name": "measurementRaw", "type": "f32" },
                    { "name": "error", "type": "f32" },
                    { "name": "pTerm", "type": "f32" },
                    { "name": "iTerm", "type": "f32" },
                    { "name": "outputRaw", "type": "f32" },
                    { "name": "output", "type": "f32" }
                ]
            },
            "groups": {
                "core": { "label": "PID Core", "order": 1 },
                "terms": { "label": "PID Terms", "order": 2 },
                "actuator": { "label": "Actuator", "order": 3 }
            },
            "signals": {
                "setpoint": {
                    "label": "Setpoint", "field": "setpoint", "group": "core", "color": "#4FC3F7",
                    "line": { "style": "dashed", "width": 2 },
                    "y_range": { "min": -2.0, "max": 2.0 }, "visible": true
                },
                "measurement": {
                    "label": "Measurement", "field": "measurement", "group": "core", "color": "#81C784",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": 0.0, "max": 1.0 }, "visible": true
                },
                "error": {
                    "label": "Error", "field": "error", "group": "core", "color": "#BA68C8",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                "output": {
                    "label": "Output", "field": "output", "group": "actuator", "color": "#FF8A65",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -100, "max": 100 }, "visible": true
                }
            }
        },
        "control": {
            "name": "Control loop",
            "panel_type": "none",
            "frame": {
                "stream_id": 2,
                "endianness": "little",
                "packed": true,
                "fields": [
                    { "name": "loopCntr", "type": "u32" },
                    { "name": "setpointL", "type": "f32" },
                    { "name": "setpointR", "type": "f32" },
                    { "name": "rampSetpointL", "type": "f32" },
                    { "name": "rampSetpointR", "type": "f32" },
                    { "name": "deltaLticks", "type": "f32" },
                    { "name": "deltaRticks", "type": "f32" }
                ]
            },
            "groups": {
                "main": { "label": "Main", "order": 1 }
            },
            "signals": {
                "setpointL": {
                    "label": "Setpoint L", "field": "setpointL", "group": "main", "color": "#4FC3F7",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                "setpointR": {
                    "label": "Setpoint R", "field": "setpointR", "group": "main", "color": "#66BB6A",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                "rampSetpointL": {
                    "label": "Ramp L", "field": "rampSetpointL", "group": "main", "color": "#EF5350",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                "rampSetpointR": {
                    "label": "Ramp R", "field": "rampSetpointR", "group": "main", "color": "#FFCA28",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                 "deltaLticks": {
                    "label": "Delta Ticks L", "field": "deltaLticks", "group": "main", "color": "#AB47BC",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                },
                "deltaRticks": {
                    "label": "Delta Ticks R", "field": "deltaRticks", "group": "main", "color": "#81C784",
                    "line": { "style": "solid", "width": 2 },
                    "y_range": { "min": -1.0, "max": 1.0 }, "visible": true
                }
            }
        },
        "imu_6axis": {
            "name": "IMU 6-Axis Raw",
            "panel_type": "imu",
            "frame": {
                "stream_id": 2,
                "endianness": "little",
                "packed": true,
                "fields": [
                    { "name": "loopCntr", "type": "u32" },
                    { "name": "motor", "type": "u8" },
                    { "name": "acc_x", "type": "f32" },
                    { "name": "acc_y", "type": "f32" },
                    { "name": "acc_z", "type": "f32" },
                    { "name": "gyro_x", "type": "f32" },
                    { "name": "gyro_y", "type": "f32" },
                    { "name": "gyro_z", "type": "f32" }
                ]
            },
            "groups": {
                "accel": { "label": "Accelerometer [g]", "order": 1 },
                "gyro": { "label": "Gyroscope [dps]", "order": 2 }
            },
            "signals": {
                "acc_x": {
                    "label": "Acc X", "field": "acc_x", "group": "accel", "color": "#EF5350",
                    "line": { "style": "solid", "width": 2 }, "y_range": { "min": -2.0, "max": 2.0 }, "visible": true
                },
                "acc_y": {
                    "label": "Acc Y", "field": "acc_y", "group": "accel", "color": "#66BB6A",
                    "line": { "style": "solid", "width": 2 }, "y_range": { "min": -2.0, "max": 2.0 }, "visible": true
                },
                "acc_z": {
                    "label": "Acc Z", "field": "acc_z", "group": "accel", "color": "#42A5F5",
                    "line": { "style": "solid", "width": 2 }, "y_range": { "min": -2.0, "max": 2.0 }, "visible": true
                },
                "gyro_x": {
                    "label": "Gyro X", "field": "gyro_x", "group": "gyro", "color": "#FFCA28",
                    "line": { "style": "dashed", "width": 1 }, "y_range": { "min": -250.0, "max": 250.0 }, "visible": false
                },
                "gyro_z": {
                    "label": "Gyro Z", "field": "gyro_z", "group": "gyro", "color": "#AB47BC",
                    "line": { "style": "dashed", "width": 1 }, "y_range": { "min": -250.0, "max": 250.0 }, "visible": false
                }
            }
