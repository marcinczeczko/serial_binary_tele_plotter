{
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  
  // Pin the interpreter to the project venv so VSCode never picks up a stale path
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  "python.languageServer": "None",
  "python.analysis.typeCheckingMode": "basic",

  "[python]": {
    // Use ruff for both formatting and import sorting — matches `uv run ruff format .`
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  "terminal.integrated.defaultProfile.osx": "zsh",
  
  "python.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/core", 
    "${workspaceFolder}/ui"
  ],

  // ---PYLINT for PYQT6 ---
  // Load PyQT6 plugin so classes are visible by linter
  "pylint.args": [
    "--extension-pkg-allow-list=PyQt6.QtWidgets,PyQt6.QtCore,PyQt6.QtGui",
    "--disable=no-member,c-extension-no-member",
    //"--variable-rgx=[a-z_][a-z0-9_]{1,30}$",  // Less restrictive nameology of variables
   // "--disable=C0114,C0115,C0116"             // Disable the need for docstrings
  ],
  "chatgpt.openOnStartup": true
}